# Sao chép thành .env rồi điền giá trị thật (.env đã gitignore, KHÔNG commit).
# Khi có test FAIL, reporter gửi tóm tắt lỗi + video lên nhóm chat Telegram.

# Token của bot (lấy từ @BotFather)
TELEGRAM_BOT_TOKEN=

# ID nhóm chat nhận thông báo (số âm cho group/supergroup, vd -1001234567890)
TELEGRAM_CHAT_ID=

# (tuỳ chọn) đổi môi trường / OTP
# RMS_BASE_URL=https://tl-nckh.vnest.vn
# RMS_OTP=123456
